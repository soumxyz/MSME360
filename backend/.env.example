# ============================================================
# MSME360 backend environment
# Copy this file to `.env` and fill in real values before running uvicorn.
# ============================================================

# --- Auth ---
# HS256 signing key for JWTs. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-real-secret
JWT_TTL_MINUTES=60

# --- CORS ---
# Comma-separated list of allowed origins for the SPA. Leave the defaults for
# local Vite dev servers; add your prod origin when deploying.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- LLM keys (all optional; if unset the copilot falls back to a canned template) ---
GEMINI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_KEY=

# --- Logging ---
LOG_LEVEL=INFO

# --- DB (optional override) ---
# MSME_DB_PATH=/absolute/path/to/msme_workspace.db
